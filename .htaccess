AuthUserFile "/home/capybara5150/oyakonojikanlabo.xyz/htpasswd/react.oyakonojikanlabo.xyz/.htpasswd"
AuthName "Member Site"
AuthType BASIC
Require valid-user

RewriteEngine On

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback to the SPA entry point for all other requests
RewriteRule ^ index.html [L]
