RewriteEngine On

# 410ページ自体は通常配信（ErrorDocument 内部参照時のループ回避）
RewriteRule ^410\.html$ - [L]

# 410レスポンス時に表示する日本語ページ
ErrorDocument 410 /410.html

# BEGIN OJL URL LIFECYCLE
# このブロックは scripts/postbuild.mjs により自動更新されます。
# END OJL URL LIFECYCLE

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback to the SPA entry point for all other requests
RewriteRule ^ index.html [L]
