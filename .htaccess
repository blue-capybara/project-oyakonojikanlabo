RewriteEngine On

# BEGIN OJL URL LIFECYCLE
# このブロックは scripts/postbuild.mjs により自動更新されます。
# END OJL URL LIFECYCLE

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback to the SPA entry point for all other requests
RewriteRule ^ index.html [L]
