[
  {
    "key": "group_event_core_d9aff845",
    "title": "Event: 基本フィールド（共通CPT）",
    "fields": [
      {
        "key": "field_event_type",
        "label": "種別",
        "name": "event_type",
        "type": "button_group",
        "choices": {
          "event": "イベント",
          "school": "スクール"
        },
        "default_value": "event",
        "layout": "horizontal",
        "return_format": "value"
      },
      {
        "key": "field_summary",
        "label": "概要",
        "name": "summary",
        "type": "textarea",
        "rows": 4,
        "new_lines": "br"
      },
      {
        "key": "field_main_image",
        "label": "メイン画像",
        "name": "main_image",
        "type": "image",
        "return_format": "array",
        "preview_size": "medium",
        "library": "all"
      },
      {
        "key": "field_schedule_tab",
        "label": "開催情報",
        "type": "tab",
        "placement": "top"
      },
      {
        "key": "field_schedule_mode",
        "label": "開催パターン",
        "name": "schedule_mode",
        "type": "select",
        "choices": {
          "single": "単発",
          "weekly": "毎週",
          "biweekly": "隔週",
          "monthly": "毎月"
        },
        "default_value": "single",
        "ui": 1
      },
      {
        "key": "field_single_slots",
        "label": "単発枠（日時の追加）",
        "name": "single_slots",
        "type": "repeater",
        "layout": "table",
        "button_label": "日時を追加",
        "conditional_logic": [
          [
            {
              "field": "field_schedule_mode",
              "operator": "==",
              "value": "single"
            }
          ]
        ],
        "sub_fields": [
          {
            "key": "field_single_date",
            "label": "日付",
            "name": "date",
            "type": "date_picker",
            "display_format": "Y-m-d",
            "return_format": "Y-m-d"
          },
          {
            "key": "field_single_start",
            "label": "開始時刻",
            "name": "start_time",
            "type": "time_picker",
            "display_format": "H:i",
            "return_format": "H:i"
          },
          {
            "key": "field_single_end",
            "label": "終了時刻",
            "name": "end_time",
            "type": "time_picker",
            "display_format": "H:i",
            "return_format": "H:i"
          }
        ]
      },
      {
        "key": "field_recurrence_group",
        "label": "繰り返し設定",
        "name": "recurrence",
        "type": "group",
        "conditional_logic": [
          [
            {
              "field": "field_schedule_mode",
              "operator": "!=",
              "value": "single"
            }
          ]
        ],
        "sub_fields": [
          {
            "key": "field_days_of_week",
            "label": "曜日",
            "name": "days_of_week",
            "type": "checkbox",
            "choices": {
              "mon": "月",
              "tue": "火",
              "wed": "水",
              "thu": "木",
              "fri": "金",
              "sat": "土",
              "sun": "日"
            },
            "conditional_logic": [
              [
                {
                  "field": "field_schedule_mode",
                  "operator": "!=",
                  "value": "monthly"
                }
              ]
            ],
            "layout": "horizontal"
          },
          {
            "key": "field_monthly_ordinal",
            "label": "第◯週（毎月用）",
            "name": "monthly_ordinal",
            "type": "select",
            "choices": {
              "1": "第1",
              "2": "第2",
              "3": "第3",
              "4": "第4",
              "5": "第5"
            },
            "allow_null": 1,
            "ui": 1,
            "conditional_logic": [
              [
                {
                  "field": "field_schedule_mode",
                  "operator": "==",
                  "value": "monthly"
                }
              ]
            ]
          },
          {
            "key": "field_time_start",
            "label": "開始時刻",
            "name": "time_start",
            "type": "time_picker",
            "display_format": "H:i",
            "return_format": "H:i"
          },
          {
            "key": "field_time_end",
            "label": "終了時刻",
            "name": "time_end",
            "type": "time_picker",
            "display_format": "H:i",
            "return_format": "H:i"
          },
          {
            "key": "field_range_start",
            "label": "開始日（開催期間）",
            "name": "range_start",
            "type": "date_picker",
            "display_format": "Y-m-d",
            "return_format": "Y-m-d"
          },
          {
            "key": "field_range_end",
            "label": "終了日（開催期間）",
            "name": "range_end",
            "type": "date_picker",
            "display_format": "Y-m-d",
            "return_format": "Y-m-d"
          }
        ]
      },
      {
        "key": "field_venue_tab",
        "label": "会場",
        "type": "tab",
        "placement": "top"
      },
      {
        "key": "field_venue_ref",
        "label": "スペース（会場）",
        "name": "venue_ref",
        "type": "post_object",
        "post_type": [
          "space"
        ],
        "return_format": "id",
        "ui": 1
      },
      {
        "key": "field_venue_maps_url",
        "label": "GoogleマップURL",
        "name": "venue_maps_url",
        "type": "url"
      },
      {
        "key": "field_price_tab",
        "label": "料金・定員・受付",
        "type": "tab",
        "placement": "top"
      },
      {
        "key": "field_price_type",
        "label": "料金区分",
        "name": "price_type",
        "type": "button_group",
        "choices": {
          "free": "無料",
          "paid": "有料"
        },
        "default_value": "free",
        "layout": "horizontal"
      },
      {
        "key": "field_price",
        "label": "価格（円）",
        "name": "price",
        "type": "number",
        "min": 0,
        "step": 1,
        "conditional_logic": [
          [
            {
              "field": "field_price_type",
              "operator": "==",
              "value": "paid"
            }
          ]
        ]
      },
      {
        "key": "field_capacity",
        "label": "定員",
        "name": "capacity",
        "type": "number",
        "min": 0,
        "step": 1
      },
      {
        "key": "field_reservation_open",
        "label": "予約受付ON",
        "name": "reservation_open",
        "type": "true_false",
        "ui": 1
      },
      {
        "key": "field_waitlist_enabled",
        "label": "キャンセル待ちON",
        "name": "waitlist_enabled",
        "type": "true_false",
        "ui": 1
      },
      {
        "key": "field_notes_tab",
        "label": "注意事項・持ち物",
        "type": "tab",
        "placement": "top"
      },
      {
        "key": "field_notes",
        "label": "注意事項",
        "name": "notes",
        "type": "textarea",
        "rows": 4
      },
      {
        "key": "field_artists_tab",
        "label": "講師/作家",
        "type": "tab",
        "placement": "top"
      },
      {
        "key": "field_artists",
        "label": "講師/作家（複数可）",
        "name": "artists",
        "type": "relationship",
        "post_type": [
          "artist"
        ],
        "filters": [
          "search"
        ],
        "return_format": "id",
        "ui": 1
      },
      {
        "key": "field_display_tab",
        "label": "公開・表示",
        "type": "tab",
        "placement": "top"
      },
      {
        "key": "field_is_published",
        "label": "公開ON",
        "name": "is_published",
        "type": "true_false",
        "ui": 1
      },
      {
        "key": "field_display_badges",
        "label": "表示バッジ",
        "name": "display_badges",
        "type": "checkbox",
        "choices": {
          "open": "受付中",
          "full": "満席",
          "ongoing": "開催中",
          "new": "新規開講"
        },
        "layout": "horizontal"
      }
    ],
    "location": [
      [
        {
          "param": "post_type",
          "operator": "==",
          "value": "event"
        }
      ]
    ],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "description": "共通CPT「event」用の基本フィールド。"
  }
]