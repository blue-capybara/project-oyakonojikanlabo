{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": {
        "contentSize": "793px"
    },
    "custom": {
      "myCustomSetting": "value"
    },
    "color": {
      "custom": true,
      "palette": [
        {
          "slug": "primary",
          "color": "#0073aa",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#005177",
          "name": "Secondary"
        }
      ]
    },
    "typography": {
      "customLineHeight": true,
      "fontSizes": [
        {
          "slug": "small",
          "size": "12px",
          "name": "Small"
        },
        {
          "slug": "regular",
          "size": "16px",
          "name": "Regular"
        },
        {
          "slug": "large",
          "size": "36px",
          "name": "Large"
        }
      ],
      "fontFamilies": [
        {
          "slug": "primary",
          "fontFamily": "Arial, sans-serif",
          "name": "Primary Font"
        }
      ],
      "lineHeight": [
        {
          "name": "Regular",
          "slug": "regular",
          "size": "1.5"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1.75"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "2"
        }
      ]
    },
    "spacing": {
      "customPadding": true,
      "blockGap": "1.5rem",
      "units": [ "px", "em", "rem", "%" ]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#000000",
      "link": "#0073aa"
    },
    "typography": {
      "fontSize": "16px",
      "fontFamily": "Arial, sans-serif",
      "lineHeight": "1.6"
    },
    "spacing": {
      "padding": "20px"
    },
    "elements": {
      "text": {
        "typography": {
          "lineHeight": "1.5"
        }
      },
      "h1": {
        "typography": {
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "lineHeight": "1.3"
        }
      }
    }
  }
}
